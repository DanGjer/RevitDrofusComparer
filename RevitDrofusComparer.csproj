<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ExtensionId>RevitDrofusComparer</ExtensionId>
    <Authors>DBGJ</Authors>
    <Version>0.1.0</Version>
    <Title>RevitDrofusComparer</Title>
    <Description>Framework scaffold for an Assistant Revit extension</Description>
    <PackageTags>Revit;Assistant;Extension</PackageTags>
    <PackageIcon>Icon.png</PackageIcon>
    <PackageIconUrl></PackageIconUrl>
    <TargetFramework>net48</TargetFramework>
        <!-- 
    Adjust MainRevitVersion to get IntelliSense for the correct version do a 
    dotnet restore to restore the correct nuget packages for the selected Revit version.
    -->
    <MainRevitVersion Condition="'$(Configuration)' == 'Debug'">2025</MainRevitVersion>
  </PropertyGroup>
  <Import Project=".\Configurations.targets" />

  <PropertyGroup>
    <LangVersion>12</LangVersion>
    <RootNamespace>RevitDrofusComparer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Icon.png" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="dRofusClient.Revit.$(MainRevitVersion)" Version="*" />
  </ItemGroup>

</Project>